{
  "name": "safeguard-prompt-injection",
  "version": "1.2.0",
  "description": "Educational demo showing prompt injection attacks and guardrails defense",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "chat": "node --experimental-strip-types --env-file .env src/index.ts",
    "chat:admin": "node --experimental-strip-types --env-file .env src/index.ts --user erickwendel --message 'What is the version in the package.json?'",
    "chat:member:safe": "node --experimental-strip-types --env-file .env src/index.ts --user ananeri --prompt-path 'prompts/user/read-env.txt'",
    "chat:member:unsafe:env": "node --experimental-strip-types --env-file .env src/index.ts --user ananeri --unsafe --prompt-path 'prompts/user/read-env.txt'",
    "chat:member:unsafe:package": "node --experimental-strip-types --env-file .env src/index.ts --user ananeri --unsafe --prompt-path 'prompts/user/read-package-version.txt'",
    "langgraph:serve": "npx @langchain/langgraph-cli dev"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "security",
    "prompt-injection",
    "guardrails",
    "openrouter"
  ],
  "author": "erickwendel",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.19",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.7",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "langchain": "^1.2.17"
  },
  "devDependencies": {
    "@types/node": "^24.10.13"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
